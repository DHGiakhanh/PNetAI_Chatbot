# ===== App =====
APP_ENV=development
LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8000

# ===== LLM (Primary) =====
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048
OPENAI_API_KEY=sk-...

# ===== LLM (Fallback) =====
LLM_FALLBACK_PROVIDER=anthropic
LLM_FALLBACK_MODEL=claude-haiku-4-5
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...

# ===== Ollama (Local Dev) =====
OLLAMA_HOST=http://localhost:11434

# ===== Response LLM — Self-Hosted / Finetune Model =====
# Dùng cho bước sinh câu trả lời cuối (response_generator node).
# Để trống RESPONSE_LLM_PROVIDER để fallback về LLM_PROVIDER (mặc định).
# Ví dụ: bật self-hosted model:
#   RESPONSE_LLM_PROVIDER=selfhosted
#   RESPONSE_LLM_MODEL=pet-bot-v1
#   SELFHOSTED_BASE_URL=http://localhost:8080/v1
#   SELFHOSTED_API_KEY=not-required
#   SELFHOSTED_TIMEOUT=60.0
RESPONSE_LLM_PROVIDER=
RESPONSE_LLM_MODEL=
SELFHOSTED_BASE_URL=http://localhost:8080/v1
SELFHOSTED_API_KEY=not-required
SELFHOSTED_TIMEOUT=60.0

# ===== Tavily =====
TAVILY_API_KEY=tvly-...

# ===== MongoDB (Chat DB — for session/history storage) =====
MONGODB_CHAT_URI=mongodb://petbot:petbot_secret@localhost:27017/pnetai_chat?authSource=admin

# ===== MongoDB (Website DB — existing, read-only) =====
MONGODB_WEBSITE_URI=mongodb://localhost:27017/pet_website

# ===== Qdrant (Vector DB) =====
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=pet_knowledge_base

# ===== Auth =====
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256

# ===== Session =====
MAX_HISTORY_MESSAGES=20
SUMMARY_TRIGGER_EVERY=10
MAX_TOOL_ITERATIONS=5
